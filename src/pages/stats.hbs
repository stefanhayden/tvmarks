{{#if error}}
  <p class='error'>{{error}}</p>
{{else}}

  <div class='stats-page'>

    <div class='stats-year-nav'>
      {{#if prevYear}}
        <a href='/stats?year={{prevYear}}' class='stats-year-nav__link'>← {{prevYear}}</a>
      {{else}}
        <span class='stats-year-nav__disabled'></span>
      {{/if}}
      <span class='stats-year-nav__current'>{{selectedYear}} Stats</span>
      {{#if nextYear}}
        <a href='/stats?year={{nextYear}}' class='stats-year-nav__link'>{{nextYear}} →</a>
      {{else}}
        <span class='stats-year-nav__disabled'></span>
      {{/if}}
    </div>

    <section class='stats-summary'>
      <div class='stats-summary-grid'>
        <div class='stats-card stats-card--1'>
          <span class='stats-card__number'>{{summary.episodes_watched}}</span>
          <span class='stats-card__label'>episodes watched</span>
        </div>
        <div class='stats-card stats-card--2'>
          <span class='stats-card__number'>{{summary.hours_watched}}</span>
          <span class='stats-card__label'>hours watched</span>
        </div>
        <div class='stats-card stats-card--3'>
          <span class='stats-card__number'>{{summary.shows_watched}}</span>
          <span class='stats-card__label'>shows watched</span>
        </div>
      </div>
    </section>

    <section class='stats-section stats-months'>
      <h2>Month by month</h2>
      <div class='stats-month-grid'>
        {{#each months}}
          <div class='stats-month'>
            <div class='stats-month__name'>{{name}}</div>
            <div class='stats-month__episodes'>
              <span class='stats-month__value'>{{episodes}}</span>
              <span class='stats-month__unit'>ep</span>
            </div>
            <div class='stats-month__bar-wrap'>
              <div class='stats-month__bar stats-month__bar--ep' style='width: {{episodesPercent}}%'></div>
            </div>
            <div class='stats-month__hours'>
              <span class='stats-month__value'>{{hours}}</span>
              <span class='stats-month__unit'>hr</span>
            </div>
            <div class='stats-month__bar-wrap'>
              <div class='stats-month__bar stats-month__bar--hr' style='width: {{hoursPercent}}%'></div>
            </div>
          </div>
        {{/each}}
      </div>
    </section>

    <div class='stats-columns'>

      <section class='stats-section'>
        <h2>Networks</h2>
        {{#if byNetwork}}
          <div class='stats-tag-list'>
            {{#each byNetwork}}
              <div class='stats-tag-row'>
                <span class='stats-tag-row__label'>{{network_name}}</span>
                <span class='stats-tag-row__count'>{{episodes_count}} ep</span>
              </div>
            {{/each}}
          </div>
        {{else}}
          <p class='stats-empty'>No data.</p>
        {{/if}}
      </section>

      <section class='stats-section'>
        <h2>Show type</h2>
        {{#if byType}}
          <div class='stats-tag-list'>
            {{#each byType}}
              <div class='stats-tag-row'>
                <span class='stats-tag-row__label'>{{type}}</span>
                <span class='stats-tag-row__count'>{{episodes_count}} ep</span>
              </div>
            {{/each}}
          </div>
        {{else}}
          <p class='stats-empty'>No data.</p>
        {{/if}}
      </section>

    </div>

    <section class='stats-section'>
      <h2>Most watched shows this year</h2>
      {{#if topShows}}
        <div class='stats-shows-list'>
          {{#each topShows}}
            <a href='/show/{{id}}' class='stats-show-row'>
              <div class='stats-show-row__info'>
                <span class='stats-show-row__name'>{{name}}</span>
                <div class='stats-show-row__bar-wrap'>
                  <div class='stats-show-row__bar' style='width: {{percent}}%'></div>
                </div>
                <span class='stats-show-row__count'>{{episodes_watched}} episodes · {{hours}}h</span>
              </div>
            </a>
          {{/each}}
        </div>
      {{else}}
        <p class='stats-empty'>No watch data yet this year.</p>
      {{/if}}
    </section>

  </div>

{{/if}}
